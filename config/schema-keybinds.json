{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gradeassist.local/schema-keybinds.json",
  "title": "Keybinds Config",
  "description": "Keyboard input bindings for the Unity simulator.",
  "type": "object",
  "required": [
    "setBenchmark",
    "moveForward",
    "moveBackward",
    "moveLeft",
    "moveRight",
    "moveUp",
    "moveDown",
    "emergencyDisable",
    "cyclePageForward",
    "cyclePageBackward",
    "pageWork",
    "pageTarget",
    "pageSystem",
    "settingsIncrement",
    "settingsDecrement",
    "settingsApply",
    "settingsCancel"
  ],
  "properties": {
    "setBenchmark": { "type": "string", "minLength": 1, "maxLength": 64 },
    "moveForward": { "type": "string", "minLength": 1, "maxLength": 64 },
    "moveBackward": { "type": "string", "minLength": 1, "maxLength": 64 },
    "moveLeft": { "type": "string", "minLength": 1, "maxLength": 64 },
    "moveRight": { "type": "string", "minLength": 1, "maxLength": 64 },
    "moveUp": { "type": "string", "minLength": 1, "maxLength": 64 },
    "moveDown": { "type": "string", "minLength": 1, "maxLength": 64 },
    "emergencyDisable": { "type": "string", "minLength": 1, "maxLength": 64 },
    "cyclePageForward": { "type": "string", "minLength": 1, "maxLength": 64 },
    "cyclePageBackward": { "type": "string", "minLength": 1, "maxLength": 64 },
    "pageWork": { "type": "string", "minLength": 1, "maxLength": 64 },
    "pageTarget": { "type": "string", "minLength": 1, "maxLength": 64 },
    "pageSystem": { "type": "string", "minLength": 1, "maxLength": 64 },
    "settingsIncrement": { "type": "string", "minLength": 1, "maxLength": 64 },
    "settingsDecrement": { "type": "string", "minLength": 1, "maxLength": 64 },
    "settingsApply": { "type": "string", "minLength": 1, "maxLength": 64 },
    "settingsCancel": { "type": "string", "minLength": 1, "maxLength": 64 }
  },
  "additionalProperties": false
}
